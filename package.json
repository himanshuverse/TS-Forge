{
  "name": "ts-forge",
  "version": "1.0.0",
  "description": "A type-safe task management engine showcasing advanced TypeScript patterns — generics, discriminated unions, mapped types, and more.",
  "main": "dist/main.js",
  "scripts": {
    "start": "ts-node src/main.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node --watch src/main.ts",
    "clean": "rm -rf dist"
  },
  "keywords": ["typescript", "task-manager", "generics", "type-safe"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}